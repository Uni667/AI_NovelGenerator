# =========================================================================
# AI Novel Generator Environment Variables Configuration Template
# =========================================================================
#
# LOCAL DEVELOPMENT:
# 1. Copy this file to a new file named `.env` in the root directory.
# 2. Under local development, the system generates random secret keys
#    if not set, but it is highly recommended to fill in mock keys.
# 3. DO NOT commit the `.env` file to your git repository.
#
# PRODUCTION ENVIRONMENT (e.g., Railway, Vercel):
# 1. DO NOT deploy the `.env` file to production.
# 2. Add these variables in the environment settings of your hosting platform.
# 3. Periodically rotate encryption keys and JWT secrets (e.g. every 90 days)
#    to maintain security integrity.
#
# HOW TO GENERATE SECURE SECRETS:
# Run this command in your terminal to generate a secure random hex string:
# python -c "import secrets; print(secrets.token_hex(32))"
# =========================================================================

# JWT signing secret (Required in production. Keep secure and random).
NEXTAUTH_SECRET=9e3cce42234d71b7d56cb3fed9168f5c57b40df759973561f68cadc3f04bdfca

# API key encryption secret (Required in production. Must be a secure hex key).
# Note: Ensure this key has sufficient entropy.
API_SECRET_ENCRYPTION_KEY=9cde42d957ae13d5c5be140d7bbaafaad424aaaa80676d252276799d498128e6

# Comma-separated frontend origins allowed by the backend CORS middleware.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
